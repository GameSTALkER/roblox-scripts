-- Murder Mystery 2

getgenv().mm2_menu_initalizing = true

while wait() do
    local r = pcall(function()
        ngamestalker:isLoaded()
    end)
    if r then
        break
    end
end

local plrs = game:GetService("Players")
local plr = plrs.LocalPlayer
local Tw = game:GetService("TweenService")
local WK = game:GetService("Workspace")

local session = ScriptSession(1)

local m = getgenv().ngamestalker:Menu(game.PlaceId,true)
local t = m:Tab()
local e = {}

if getgenv().mm2_connection == nil then getgenv().mm2_connection = {}
else
    for i,v in pairs(getgenv().mm2_connection) do
        pcall(function() getgenv().mm2_connection[i]:Disconnect() end)
        getgenv().mm2_connection[i] = nil
    end
    getgenv().mm2_connection = {}
end

local function marker(tool,part,col)
    col = col or Color3.fromRGB(100,255,100)
    local function esp(col,text)
        local wh = part:FindFirstChild("ESP")
        if wh then
            wh.T.TextColor3 = col
            wh.T.Text = text
        else
            local BillboardGui = Instance.new("BillboardGui",part)
                BillboardGui.Name = "ESP"
                BillboardGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
                BillboardGui.Active = true
                BillboardGui.AlwaysOnTop = true
                BillboardGui.LightInfluence = 1.000
                BillboardGui.Size = UDim2.new(0, 200, 0, 50)
            
            local TextLabel = Instance.new("TextLabel",BillboardGui)
                TextLabel.Name = "T"
                TextLabel.BackgroundTransparency = 1.000
                TextLabel.Size = UDim2.new(0, 200, 0, 50)
                TextLabel.Font = getgenv().ngamestalker:Info().Theme.Font
                TextLabel.TextTransparency = 0
                TextLabel.Text = text
                TextLabel.TextColor3 = col
                TextLabel.TextSize = 14.000
                
            local UIG = Instance.new("UIGradient",TextLabel)
                UIG.Color = getgenv().ngamestalker:Info().Theme.gradient.text
                UIG.Rotation = 45
                UIG.Offset = Vector2.new(0,0.3)
        end
        
    end
    if tool.Name == "Gun" then
        esp(Color3.fromRGB(100,100,255),"Sheriff")
    elseif tool.Name == "Knife" then
        esp(Color3.fromRGB(255,100,100),"Murder")
    else
        esp(col,tool.Name)
    end
end

local function getTool(v)
    local char = v.Character
    if char then
        return (v.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")) or (v.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")) or {Name="Innocent"}
    end
    return {Name="Innocent"}
end

local function getMap()
    local CurrentMap = false
    for i,v in pairs(WK:GetChildren()) do
        if v:FindFirstChild("Map") then 
            CurrentMap = v
            local spawns = v:WaitForChild("Spawns")
            local vloer = spawns:FindFirstChild("Vloer")
            if not vloer then
                vloer = Instance.new("Part",spawns)
                vloer.Name = "Vloer"
                vloer.CanCollide = true
                vloer.Anchored = true
                vloer.Size = Vector3.new(500,2,500)
                vloer.Position = spawns:FindFirstChild("Spawn").Position - Vector3.new(0,25,0)
            end
            
            break
        end
    end
   
    return CurrentMap 
end
local function ChangeNDesc(n,b,t)
    pcall(function() if n then n:Desc(t) end end)
    local oldName = b:Info().Name
    b:Edit({name=t})
    wait(1)
    b:Edit({name=oldName})
end

getgenv().mm2_connection["WALLHACK"] = false
e["WHb"] = t:Toggle({name="Player WH",desc="Will show who are murder or sheriff",key="false"},function(state)
    if getgenv().mm2_menu_initalizing == true then e["WHb"]:Edit({state=not state}) return end
    getgenv().mm2_connection["WALLHACK"] = state
    if state then
        spawn(function()
            while getgenv().mm2_connection["WALLHACK"] and wait(1) do
                for i,v in pairs(plrs:GetPlayers()) do
                    pcall(function()
                        if v.Name ~= plr.Name then
                            local char = v.Character
                            if char then 
                                local tool = getTool(v)
                                marker(tool,char.HumanoidRootPart)
                            end
                        end
                    end)
                    wait()
                end
            end
            for i,v in pairs(plrs:GetPlayers()) do
                local char = v.Character
                if char then 
                    local a = char.HumanoidRootPart:FindFirstChild("ESP")
                    if a then a.T.Text = "" end
                end
                wait()
            end
        end)
    end
end)
getgenv().mm2_connection["WALLHACKGUN"] = false
e["Gunt"] = t:Toggle({name="Dropped gun WH",key="false"},function(state)
    if getgenv().mm2_menu_initalizing == true then e["Gunt"]:Edit({state=not state}) return end
    getgenv().mm2_connection["WALLHACKGUN"] = state
    if state then
